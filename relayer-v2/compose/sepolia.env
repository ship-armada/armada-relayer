# ABOUTME: Committed non-secret env for NETWORK=sepolia (spec §11.1). RPC URLs live ONLY in
# ABOUTME: secrets.env (single source of truth) — keyed URLs are secrets and must not be here.
NETWORK=sepolia

# Central deployment registry (spec §7.2): resolves addresses from
# deployments/registry/testnet/<instance>/<chain>/privacy-pool.json. Run
# `git submodule update --init deployments/registry` before `docker compose up`.
DEPLOYMENT_INSTANCE=demo1

# DB passwords for a real deployment belong in secrets.env; these are placeholders that
# compose overrides when secrets.env defines the same variables.
POSTGRES_PASSWORD=change-me-in-secrets-env
WATCHER_DB_PASSWORD=change-me-in-secrets-env
ACTOR_DB_PASSWORD=change-me-in-secrets-env

# RPC endpoints (HUB_RPC / CLIENT_A_RPC / CLIENT_B_RPC) are set ONLY in secrets.env so the
# whole provider list lives in one place (§11.1) — comma-separated; the watcher pools every
# URL, the actor uses the first. Boot fails loudly if secrets.env leaves them unset.

# Chainlink ETH/USD on Ethereum Sepolia (hub chain, §8.8).
ETH_USD_FEED_ADDRESS=0x694AA1769357215DE4FAC081bf1f309aDC325306
# Emergency price floor — keep roughly current (§8.8.3).
# Verified against the live feed via `npx tsx e2e/verify-feed.mts` (actor package);
# update when ETH moves materially.
ETH_USD_PRICE_STATIC=1800
