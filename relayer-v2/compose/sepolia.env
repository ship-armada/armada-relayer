# ABOUTME: Committed non-secret env for NETWORK=sepolia (spec §11.1). RPC URLs with embedded
# ABOUTME: paid keys are SECRETS — set them in secrets.env instead; public URLs may live here.
NETWORK=sepolia

# DB passwords for a real deployment belong in secrets.env; these are placeholders that
# compose overrides when secrets.env defines the same variables.
POSTGRES_PASSWORD=change-me-in-secrets-env
WATCHER_DB_PASSWORD=change-me-in-secrets-env
ACTOR_DB_PASSWORD=change-me-in-secrets-env

# Public fallback RPC endpoints (§11.1). Prefer the paid-key URLs from secrets.env.
HUB_RPC=https://ethereum-sepolia-rpc.publicnode.com
CLIENT_A_RPC=https://base-sepolia-rpc.publicnode.com
CLIENT_B_RPC=https://arbitrum-sepolia-rpc.publicnode.com

# Chainlink ETH/USD on Ethereum Sepolia (hub chain, §8.8).
ETH_USD_FEED_ADDRESS=0x694AA1769357215DE4FAC081bf1f309aDC325306
# Emergency price floor — keep roughly current (§8.8.3).
# Verified against the live feed via `npx tsx e2e/verify-feed.mts` (actor package);
# update when ETH moves materially.
ETH_USD_PRICE_STATIC=1800
