# ABOUTME: Committed non-secret env for NETWORK=mainnet (spec §7.2, §11.1). Mainnet is a
# ABOUTME: configuration posture: this file must stay valid even before mainnet manifests exist.
NETWORK=mainnet

POSTGRES_PASSWORD=change-me-in-secrets-env
WATCHER_DB_PASSWORD=change-me-in-secrets-env
ACTOR_DB_PASSWORD=change-me-in-secrets-env

# Public fallback RPC endpoints; paid-key URLs go in secrets.env (§11.1).
HUB_RPC=https://ethereum-rpc.publicnode.com
CLIENT_A_RPC=https://base-rpc.publicnode.com
CLIENT_B_RPC=https://arbitrum-one-rpc.publicnode.com

# Chainlink ETH/USD on Ethereum mainnet (hub chain, §8.8).
ETH_USD_FEED_ADDRESS=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419
# Verified against the live feed via `npx tsx e2e/verify-feed.mts` (actor package);
# update when ETH moves materially.
ETH_USD_PRICE_STATIC=1800
