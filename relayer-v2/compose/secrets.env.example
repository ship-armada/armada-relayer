# ABOUTME: Template for relayer-v2/compose/secrets.env (gitignored; spec §11.1). Copy to
# ABOUTME: secrets.env and fill in. NEVER commit the real file — the pre-commit hook blocks it.
# cp secrets.env.example secrets.env

# Actor keys (D2: these reach ONLY the actor container).
RELAYER_PRIVATE_KEY=0x...
RELAYER_RAILGUN_MNEMONIC="word1 word2 ... word12"
# Optional: assert the derived 0zk address matches (boot-fails on mismatch, §6.5).
#BROADCASTER_RAILGUN_ADDRESS=0zk1...

# Database passwords (compose env-file layering overrides the committed placeholders).
#POSTGRES_PASSWORD=...
#WATCHER_DB_PASSWORD=...
#ACTOR_DB_PASSWORD=...

# Paid RPC URLs with embedded keys are secrets (§11.1). They override the public fallbacks.
# Comma-separated lists are allowed: the watcher load-balances across every URL (more
# free-tier throughput for backfills); the actor uses only the FIRST entry.
#HUB_RPC=https://eth-sepolia.g.alchemy.com/v2/KEY,https://sepolia.drpc.org
#CLIENT_A_RPC=...
#CLIENT_B_RPC=...
