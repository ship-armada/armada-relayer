# ABOUTME: Committed non-secret env for NETWORK=local (spec §11.1). Local-only credentials
# ABOUTME: are intentionally weak; real secrets belong in secrets.env (gitignored).
NETWORK=local

# Local Postgres credentials (compose-internal only; S4 keeps the port unexposed).
POSTGRES_PASSWORD=local-postgres-pw
WATCHER_DB_PASSWORD=local-watcher-pw
ACTOR_DB_PASSWORD=local-actor-pw

# Anvil chains run on the host (`npm run chains`); containers reach them via host-gateway.
HUB_RPC=http://host.docker.internal:8545
CLIENT_A_RPC=http://host.docker.internal:8546
CLIENT_B_RPC=http://host.docker.internal:8547

# Fee formula price input (§8.8): local mode uses the static value (no feed on Anvil).
# Matches v1's ETH_USDC_PRICE default so local fee quotes are value-identical.
ETH_USD_PRICE_STATIC=2000

# LOCAL-ONLY dev wallet material. These are the universally-known Anvil/Hardhat test values
# (public knowledge, safe to commit); real networks take theirs from secrets.env.
RELAYER_RAILGUN_MNEMONIC="test test test test test test test test test test test junk"
